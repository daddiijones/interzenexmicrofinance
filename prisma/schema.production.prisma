// MySQL schema used only in production (Namecheap cPanel). Local dev uses
// prisma/schema.prisma (SQLite) instead — see DEPLOYMENT.md.
//
// Keep models in sync with prisma/schema.prisma when the shape changes.

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 Int             @id @default(autoincrement())
  email              String          @unique
  password           String
  name               String
  role               String          @default("USER") // USER, ADMIN
  country            String          @default("") // ISO 3166-1 alpha-2 country code
  accountNumber      String          @unique
  dailyLimit         Float           @default(5000.0)
  spentToday         Float           @default(0.0)
  status             String          @default("ACTIVE") // ACTIVE, RESTRICTED, SUSPENDED
  transferCount      Int             @default(5)  // max transfers allowed per day; 0 = unlimited
  restrictionMessage String          @default("") @db.Text
  approvalCode       String          @default("") // admin-assigned code user enters to exceed transfer count
  otpCode            String          @default("") // pending login OTP, cleared after verification
  otpExpiresAt       DateTime?       // expiry for the pending login OTP
  otpLastSentAt      DateTime?       // used to enforce the resend cooldown
  createdAt          DateTime        @default(now())
  accounts           Account[]
  loans              Loan[]
  tickets            SupportTicket[]
}

model Account {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // CHECKING, SAVINGS, INVESTMENT
  balance       Float    @default(0.0)
  currency      String   @default("USD") // ISO 4217 code, see src/lib/currencies.js
  accountNumber String   @unique
  createdAt     DateTime @default(now())
}

model Transaction {
  id                    Int      @id @default(autoincrement())
  senderId              Int?
  senderAccountNumber   String?
  senderName            String?
  receiverId            Int?
  receiverAccountNumber String
  receiverBank          String   @default("Apex Bank")
  receiverName          String
  amount                Float
  currency              String   @default("USD")
  convertedAmount       Float
  conversionRate        Float    @default(1.0)
  type                  String   // TRANSFER, DEPOSIT, WITHDRAWAL, BILL_PAY, CARD_SPEND
  status                String   @default("COMPLETED") // COMPLETED, PENDING, FAILED
  description           String   @db.Text
  createdAt             DateTime @default(now()) // Can be backdated
}

model Card {
  id            Int      @id @default(autoincrement())
  userId        Int
  cardNumber    String   @unique
  cardholderName String
  expiryDate    String
  cvv           String
  cardType      String   @default("DEBIT") // DEBIT, CREDIT
  status        String   @default("ACTIVE") // ACTIVE, FROZEN
  dailyLimit    Float    @default(2000.0)
  createdAt     DateTime @default(now())
}

model Loan {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount         Float
  interestRate   Float
  durationMonths Int
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  purpose        String   @db.Text
  createdAt      DateTime @default(now())
}

model SupportTicket {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    String
  message    String   @db.Text
  status     String   @default("OPEN") // OPEN, RESOLVED
  adminReply String   @default("") @db.Text
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  adminName String
  action    String
  details   String   @db.Text
  createdAt DateTime @default(now())
}
